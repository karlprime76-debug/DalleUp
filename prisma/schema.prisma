generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  RESTAURANT
  DELIVERY_DRIVER
  ADMIN
}

enum OrderStatus {
  CART
  PENDING_PAYMENT
  PAID_WAITING_RESTAURANT
  ACCEPTED
  PREPARING
  READY
  DRIVER_ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELLED
  REFUND_REQUIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUND_REQUIRED
  REFUNDED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MTN_MOMO
  MOOV_MONEY
  CARD
  PAYDUNYA
  MOCK
}

enum PaymentPurpose {
  ORDER_PAYMENT
  RESTAURANT_SUBSCRIPTION
  RESTAURANT_BOOST
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum PayoutMethod {
  MTN_MONEY
  MOOV_MONEY
  PAYDUNYA
  MANUAL
}

enum RestaurantPlacementType {
  HOME_FEATURED
  SPONSORED_LISTING
  TRENDING_DISHES
  SEARCH_PRIORITY
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  FAILED
}

enum RestaurantStatus {
  PENDING
  APPROVED
  SUSPENDED
  CLOSED
}

enum DriverStatus {
  PENDING
  AVAILABLE
  OFFLINE
  ON_DELIVERY
  SUSPENDED
  REJECTED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum AdminAuditAction {
  RESTAURANT_STATUS_UPDATED
  DRIVER_STATUS_UPDATED
  INVOICE_STATUS_UPDATED
  FINANCIAL_REPORT_EXPORTED
  BILLING_NOTIFICATION_STATUS_UPDATED
  BILLING_NOTIFICATIONS_EXPORTED
  PLATFORM_SETTINGS_UPDATED
}

enum BillingNotificationType {
  SUBSCRIPTION_UPDATED
  INVOICE_GENERATED
  INVOICE_PAID
  INVOICE_STATUS_UPDATED
}

enum BillingNotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  image         String?
  passwordHash  String?
  phone         String?
  role          UserRole     @default(CLIENT)
  driverStatus  DriverStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  restaurants   Restaurant[]
  addresses     Address[]
  orders        Order[]      @relation("CustomerOrders")
  deliveries    Delivery[]   @relation("DriverDeliveries")
  reviews       Review[]
  favorites     Favorite[]
  accounts      Account[]
  sessions      Session[]
  adminAuditLogs AdminAuditLog[]
  billingNotifications BillingNotification[]
  wallet               Wallet?
  payouts              Payout[]
  notifications        Notification[]
  vehicleType          String?
  city                 String?
  pushSubscriptions    PushSubscription[]
  verificationStatus   String?
  verificationSubmittedAt DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RestaurantCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  restaurants Restaurant[]
}

model Restaurant {
  id          String             @id @default(cuid())
  ownerId     String
  categoryId  String?
  name        String
  slug        String             @unique
  description String
  image       String?
  address     String
  phone       String?
  status      RestaurantStatus   @default(PENDING)
  rating      Float              @default(0)
  deliveryFee Int                @default(1200)
  minDelayMin Int                @default(20)
  maxDelayMin Int                @default(40)
  isPopular   Boolean            @default(false)
  currentPlanCode String?
  isSponsored   Boolean          @default(false)
  sponsoredUntil DateTime?
  isFeatured    Boolean          @default(false)
  featuredUntil DateTime?
  priorityScore Int              @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerId], references: [id])
  category    RestaurantCategory? @relation(fields: [categoryId], references: [id])
  menuCategories MenuCategory[]
  menuItems   MenuItem[]
  orders      Order[]
  reviews     Review[]
  favorites   Favorite[]
  subscriptions RestaurantSubscription[]
  invoices    Invoice[]
  placements  RestaurantPlacement[]
  billingNotifications BillingNotification[]
  promoCodes  PromoCode[]
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  items        MenuItem[]
}

model MenuItem {
  id          String        @id @default(cuid())
  restaurantId String
  categoryId  String?
  name        String
  description String
  price       Int
  image       String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  restaurant  Restaurant    @relation(fields: [restaurantId], references: [id])
  category    MenuCategory? @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String
  restaurantId   String
  addressId      String?
  status         OrderStatus   @default(PENDING_PAYMENT)
  subtotal       Int
  deliveryFee    Int
  serviceFee     Int           @default(0)
  total          Int
  note           String?
  paymentStatus  PaymentStatus @default(PENDING)
  payoutStatus   PayoutStatus?
  paidAt         DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  refundedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       User          @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id])
  address        Address?      @relation(fields: [addressId], references: [id])
  items          OrderItem[]
  delivery       Delivery?
  payment        Payment?
  review           Review?
  platformRevenue  PlatformRevenue?
  orderSplit     OrderSplit?
  payoutTransfers PayoutTransfer[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Int
  total      Int
  order      Order    @relation(fields: [orderId], references: [id])
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Delivery {
  id               String         @id @default(cuid())
  orderId          String         @unique
  driverId         String?
  status           DeliveryStatus @default(PENDING)
  distanceKm       Float?
  currentLatitude  Float?
  currentLongitude Float?
  lastLocationAt   DateTime?
  trackingEnabled  Boolean        @default(false)
  pickedAt         DateTime?
  deliveredAt      DateTime?
  order            Order          @relation(fields: [orderId], references: [id])
  driver           User?          @relation("DriverDeliveries", fields: [driverId], references: [id])
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String
  street    String
  city      String
  zone      String?
  latitude  Float?
  longitude Float?
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])
  orders    Order[]

  @@unique([userId, street, city])
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String?         @unique
  restaurantId  String?
  purpose       PaymentPurpose  @default(ORDER_PAYMENT)
  method        PaymentMethod   @default(CASH_ON_DELIVERY)
  provider      String?
  providerToken String?
  providerRef   String?
  checkoutUrl   String?
  status        PaymentStatus   @default(PENDING)
  amount        Int
  currency      String          @default("XOF")
  paidAt        DateTime?
  failedAt      DateTime?
  raw           Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order?          @relation(fields: [orderId], references: [id])
  subscription  RestaurantSubscription?
}

model BillingPlan {
  id             String                   @id @default(cuid())
  code           String                   @unique
  name           String                   @unique
  description    String?
  price          Int                      @default(0)
  currency       String                   @default("XOF")
  durationDays   Int                      @default(30)
  monthlyFee     Int                      @default(0)
  commissionRate Int                      @default(15)
  interval       BillingInterval          @default(MONTHLY)
  features       Json?
  priorityScore  Int                      @default(0)
  allowPromoCodes Boolean               @default(false)
  maxActivePromoCodes Int                @default(0)
  allowSponsoredPlacement Boolean        @default(false)
  allowFeaturedDishes Boolean            @default(false)
  allowAdvancedStats Boolean             @default(false)
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  subscriptions  RestaurantSubscription[]
}

model RestaurantSubscription {
  id           String             @id @default(cuid())
  restaurantId String
  planId       String
  paymentId    String?            @unique
  status       SubscriptionStatus @default(PENDING_PAYMENT)
  startsAt     DateTime?
  endsAt       DateTime?
  autoRenew    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id])
  plan         BillingPlan        @relation(fields: [planId], references: [id])
  payment      Payment?           @relation(fields: [paymentId], references: [id])
  invoices     Invoice[]
}

model Invoice {
  id             String                  @id @default(cuid())
  restaurantId   String
  subscriptionId String?
  number         String                  @unique
  status         InvoiceStatus           @default(OPEN)
  amount         Int
  commission     Int                     @default(0)
  dueAt          DateTime?
  paidAt         DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  restaurant     Restaurant              @relation(fields: [restaurantId], references: [id])
  subscription   RestaurantSubscription? @relation(fields: [subscriptionId], references: [id])
}

model AdminAuditLog {
  id          String           @id @default(cuid())
  adminId     String
  action      AdminAuditAction
  targetType  String
  targetId    String?
  targetLabel String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  admin       User             @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model BillingNotification {
  id           String                    @id @default(cuid())
  userId       String?
  restaurantId String?
  type         BillingNotificationType
  status       BillingNotificationStatus @default(PENDING)
  title        String
  message      String
  metadata     Json?
  createdAt    DateTime                  @default(now())
  sentAt       DateTime?
  user         User?                     @relation(fields: [userId], references: [id])
  restaurant   Restaurant?               @relation(fields: [restaurantId], references: [id])

  @@index([status, createdAt])
  @@index([restaurantId, createdAt])
}

model Review {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  orderId      String?    @unique
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  order        Order?     @relation(fields: [orderId], references: [id])
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
}

model PromoCode {
  id               String        @id @default(cuid())
  restaurantId     String?
  code             String        @unique
  title            String?
  description      String?
  discountType     DiscountType?
  discountValue    Int?
  minOrderAmount   Int?
  maxDiscountAmount Int?
  usageLimit       Int?
  usageCount       Int           @default(0)
  perCustomerLimit Int?
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  restaurant       Restaurant?   @relation(fields: [restaurantId], references: [id])
  usages           PromoCodeUsage[]

  @@index([restaurantId, isActive])
}

model PromoCodeUsage {
  id             String      @id @default(cuid())
  promoCodeId    String
  userId         String?
  orderId        String?
  discountAmount Int
  usedAt         DateTime    @default(now())
  promoCode      PromoCode   @relation(fields: [promoCodeId], references: [id])
}

model PlatformSettings {
  id                          String   @id @default(cuid())
  platformName                String   @default("DalleUp")
  platformSlogan              String   @default("Commande. Chill. On livre.")
  supportEmail                String   @default("support@dalleup.com")
  supportPhone                String   @default("")
  whatsappPhone               String   @default("")
  currency                    String   @default("F CFA")
  country                     String   @default("Bénin")
  city                        String   @default("Cotonou")

  defaultDeliveryFee          Int      @default(500)
  deliveryFeePerKm            Int      @default(100)
  freeDeliveryThreshold       Int      @default(10000)
  minOrderAmount              Int      @default(1000)
  maxDeliveryDistanceKm       Int      @default(15)
  estimatedPrepTimeMin        Int      @default(20)
  estimatedDeliveryTimeMin    Int      @default(30)

  restaurantCommissionRate    Int      @default(15)
  deliveryCommissionRate      Int      @default(0)
  platformServiceFee          Int      @default(0)
  restaurantPayoutDelayDays   Int      @default(7)
  driverPayoutDelayDays       Int      @default(7)

  allowCashPayment            Boolean  @default(true)
  allowMobileMoneyPayment     Boolean  @default(true)
  allowCardPayment            Boolean  @default(false)

  autoAcceptOrders            Boolean  @default(false)
  autoCancelUnpaidOrders      Boolean  @default(true)
  autoCancelDelayMinutes      Int      @default(15)
  allowClientOrderCancellation  Boolean  @default(true)
  allowRestaurantOrderCancellation Boolean @default(true)
  clientCancellationWindowMin Int      @default(5)

  manualRestaurantApproval    Boolean  @default(true)
  allowRestaurantSelfProducts Boolean  @default(true)
  allowRestaurantPriceEdit    Boolean  @default(true)
  autoHideClosedRestaurants   Boolean  @default(true)
  minRatingForFeature         Float    @default(4.0)

  manualDriverApproval        Boolean  @default(true)
  enableAutoDriverAssign      Boolean  @default(false)
  driverSearchRadiusKm        Int      @default(5)
  driverAcceptTimeoutSec      Int      @default(300)
  driverMinFee                Int      @default(300)
  driverDeliveryBonusEnabled  Boolean  @default(false)
  allowDriverRefusal          Boolean  @default(true)

  enableSponsoredRestaurants  Boolean  @default(true)
  sponsoredRestaurantDailyPrice   Int @default(2000)
  sponsoredRestaurantWeeklyPrice  Int @default(10000)
  sponsoredRestaurantMonthlyPrice Int @default(30000)
  maxSponsoredRestaurants         Int @default(6)
  sponsoredDefaultDurationDays    Int @default(7)
  sponsoredDefaultStatus          String @default("pending")

  enableTrendingDishes        Boolean  @default(true)
  trendingDishDailyPrice      Int      @default(1000)
  trendingDishWeeklyPrice     Int      @default(5000)
  trendingDishMonthlyPrice    Int      @default(15000)
  maxTrendingDishes           Int      @default(8)
  trendingDefaultDurationDays Int      @default(7)
  trendingDefaultStatus       String   @default("pending")

  enablePushNotifications     Boolean  @default(true)
  enableEmailNotifications      Boolean  @default(true)
  enableSmsNotifications        Boolean  @default(false)
  enableWhatsappNotifications   Boolean  @default(false)

  notifyNewOrderClient          Boolean  @default(true)
  notifyNewOrderRestaurant      Boolean  @default(true)
  notifyOrderAccepted           Boolean  @default(true)
  notifyOrderRejected           Boolean  @default(true)
  notifyDriverAssigned          Boolean  @default(true)
  notifyOrderOnTheWay           Boolean  @default(true)
  notifyOrderDelivered          Boolean  @default(true)
  notifyPaymentConfirmed        Boolean  @default(true)
  notifyPaymentFailed           Boolean  @default(true)
  notifyNewRestaurant           Boolean  @default(true)
  notifyNewDriver               Boolean  @default(true)
  notifyNewSponsoring           Boolean  @default(true)

  maintenanceMode             Boolean  @default(false)
  maintenanceMessage          String   @default("DalleUp est temporairement en maintenance. Merci de revenir dans quelques minutes.")
  allowAdminInMaintenance     Boolean  @default(true)
  disableOrdersTemporarily    Boolean  @default(false)
  disableRestaurantSignup     Boolean  @default(false)
  disableDriverSignup         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

enum LedgerEntryType {
  RESTAURANT_PAYOUT
  DRIVER_PAYOUT
  PLATFORM_REVENUE
}

enum LedgerEntryDirection {
  CREDIT
  DEBIT
}

enum LedgerEntryStatus {
  PENDING
  SETTLED
  FAILED
}

enum PayoutStatus {
  REQUESTED
  PENDING
  PROCESSING
  PAID
  FAILED
  READY_TO_PAY
  SUCCESS
  RETRY_REQUIRED
  MANUALLY_PAID
  BLOCKED_MISSING_PAYOUT_ACCOUNT
  BLOCKED_UNVERIFIED_PAYOUT_ACCOUNT
}

enum SettlementBatchStatus {
  OPEN
  CLOSED
}

model Wallet {
  id             String        @id @default(cuid())
  userId         String        @unique
  balance        Int           @default(0)
  pendingBalance Int           @default(0)
  currency       String        @default("XOF")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  entries        LedgerEntry[]
}

model LedgerEntry {
  id          String              @id @default(cuid())
  walletId    String
  orderId     String?
  type        LedgerEntryType
  amount      Int
  direction   LedgerEntryDirection
  status      LedgerEntryStatus     @default(PENDING)
  description String?
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id])
}

model PlatformRevenue {
  id                   String   @id @default(cuid())
  orderId              String   @unique
  foodSubtotal         Int
  deliveryFee          Int
  restaurantCommission Int
  deliveryCommission   Int
  restaurantPayout     Int
  driverPayout         Int
  totalPlatformRevenue Int
  createdAt            DateTime @default(now())
  order                Order    @relation(fields: [orderId], references: [id])
}

model Payout {
  id          String      @id @default(cuid())
  userId      String
  amount      Int
  status      PayoutStatus @default(REQUESTED)
  method      String?
  reference   String?
  requestedAt DateTime     @default(now())
  paidAt      DateTime?
  user        User         @relation(fields: [userId], references: [id])
}

enum NotificationType {
  ORDER_STATUS
  ORDER_NEW
  VALIDATION_APPROVED
  VALIDATION_REJECTED
  PAYOUT_STATUS
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SettlementBatch {
  id            String                @id @default(cuid())
  periodStart   DateTime
  periodEnd     DateTime
  totalRestaurants Int
  totalDrivers     Int
  totalPlatform    Int
  status           SettlementBatchStatus @default(OPEN)
  createdAt        DateTime            @default(now())
}

model OrderSplit {
  id                        String      @id @default(cuid())
  orderId                   String      @unique
  subtotalAmount            Int
  deliveryFeeAmount         Int
  serviceFeeAmount          Int
  totalAmount               Int
  restaurantCommissionRate  Int
  restaurantCommissionAmount Int
  deliveryCommissionRate    Int
  deliveryCommissionAmount  Int
  restaurantAmount          Int
  courierAmount             Int
  dalleupAmount             Int
  status                    PayoutStatus @default(PENDING)
  calculatedAt              DateTime     @default(now())
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  order                     Order        @relation(fields: [orderId], references: [id])
}

enum PayoutOwnerType {
  RESTAURANT
  COURIER
}

model PayoutAccount {
  id            String          @id @default(cuid())
  ownerType     PayoutOwnerType
  ownerId       String
  provider      String
  method        String
  phone         String?
  accountAlias  String?
  accountName   String?
  isVerified    Boolean         @default(false)
  verifiedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  adminNote     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([ownerType, ownerId, provider, method])
}

model PayoutTransfer {
  id              String        @id @default(cuid())
  orderId         String
  beneficiaryType PayoutOwnerType
  beneficiaryId   String
  payoutAccountId String?
  amount          Int
  currency        String        @default("XOF")
  provider        String
  providerToken   String?
  providerRef     String?
  status          PayoutStatus  @default(PENDING)
  attempts        Int           @default(0)
  lastError       String?
  raw             Json?
  processedAt     DateTime?
  manuallyPaidAt  DateTime?
  manualNote      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  order           Order         @relation(fields: [orderId], references: [id])

  @@unique([orderId, beneficiaryType, beneficiaryId])
  @@index([status, createdAt])
}

model RestaurantPlacement {
  id             String                   @id @default(cuid())
  restaurantId   String
  subscriptionId String?
  type           RestaurantPlacementType
  startsAt       DateTime                 @default(now())
  endsAt         DateTime?
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  restaurant     Restaurant               @relation(fields: [restaurantId], references: [id])
}
